{
  "version": "2026-03-06",
  "owners": {
    "docs/framework/**": ["hivefiver", "hiveplanner", "hiveq"],
    "docs/implementation/**": ["hivemaker", "hivehealer", "hitea", "hiveq"]
  },
  "constraints": {
    "hivefiver_blind_mode": {
      "read": "deny",
      "glob": "deny",
      "grep": "deny",
      "required_delegation_target": "hivexplorer"
    },
    "state_write_authority": {
      "allowed_pattern": "tool-driven queue flush path",
      "disallowed_pattern": "direct .hivemind/state writes from plugin hooks"
    }
  }
}
