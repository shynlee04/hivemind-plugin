{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/universal-rules.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./dist/plugin.js",
    "./.planning/spikes/003-custom-tool-wrapper/spike-plugin.js"
  ],
  "provider": {
    "opencode-go": {
      "models": {
        "deepseek-v4-pro": {
          "options": {
            "reasoningEffort": "max"
          }
        },
        "small": {
          "id": "deepseek-v4-flash",
          "options": {
            "reasoningEffort": "max"
          }
        }
      }
    },
    "zai-codng-plan": {
      "models": {
        "large": {
          "id": "glm-5.1"
        }
      }
    }
  },
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow"
    },
    "task": "allow",
    "skill": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "mcp": "allow",
    "doom_loop": "allow",
    "question": "allow",
    "apply_patch": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  }
}