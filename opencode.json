    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io/https://github.com/anomalyco/opencode/https://github.com/anomalyco/opencode",
      "enabled": true,
      "timeout": 15000
    },
    "fetcher": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "fetcher-mcp"
      ],
      "enabled": true,
      "timeout": 30000
