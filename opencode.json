{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/universal-rules.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./dist/plugin.js"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 5000
  },
  "provider": {
    "crof": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CrofAI",
      "options": {
        "baseURL": "https://crof.ai/v1",
        "apiKey": "{env:CROF_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "CrofAI: deepseek-v3.2",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "deepseek-v4-pro-precision": {
          "name": "CrofAI: deepseek-v4-pro (precision)",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "deepseek-v4-flash": {
          "name": "CrofAI: deepseek-v4-flash",
          "limit": { "context": 1000000, "output": 131072 }
        },
        "deepseek-v3.2": {
          "name": "CrofAI: deepseek-v3.2",
          "limit": { "context": 163840, "output": 163840 }
        },
        "kimi-k2.6": {
          "name": "CrofAI: kimi-k2.6",
          "limit": { "context": 262144, "output": 262144 }
        },
        "kimi-k2.6-precision": {
          "name": "CrofAI: kimi-k2.6 (precision)",
          "limit": { "context": 262144, "output": 262144 }
        },
        "kimi-k2.5": {
