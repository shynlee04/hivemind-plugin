{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=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",
      "enabled": true,
      "timeout": 15000
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "repomix": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "repomix",
        "--mcp"
      ],
      "enabled": true
    },
    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "fetcher": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "fetcher-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "plugin": [
    "hivemind-context-governance"
  ],
  "provider": {
    "chutes-api": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Chutes AI",
      "options": {
        "baseURL": "https://llm.chutes.ai/v1"
      },
      "models": {
        "e51e818e-fa63-570d-9f68-49d7d1b4d12f": {
          "name": "GLM-5-TEE"
        },
        "ce6a92e4-5c2f-5681-9742-c80a4447bbdf": {
          "name": "MiniMax-M2.5-TEE"
        },
        "572bd930-0438-520c-a4a4-56874be296f8": {
          "name": "GLM-4.7-FP8"
        }
      }
    },
    "aihubmix-code": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "AIHubMix-code",
      "options": {
        "baseURL": "https://aihubmix.com/v1"
      },
      "models": {
        "coding-glm-5-free": {
          "name": "CODING-GLM-5-FREE"
        },
        "coding-minimax-m2.5-free": {
          "name": "CODING-MINIMAX-M2.5-FREE"
        }
      }
    }
  },
  "model": "chutes-api/e51e818e-fa63-570d-9f68-49d7d1b4d12f",
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": "ask",
    "*": "ask"
  },
  "agent": {
    "hivefiver": {
      "mode": "primary",
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "task": true,
        "skill": true,
        "webfetch": true,
        "websearch": true,
        "bash": true
      }
    }
  }
}
