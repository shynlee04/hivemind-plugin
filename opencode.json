{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/universal-rules.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./dist/plugin.js"
  ],
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow"
    },
    "task": "allow",
    "skill": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "doom_loop": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}