{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-coding-plan/MiniMax-M2.7",
  "plugin": [
    ".opencode/plugins/hivemind-context-governance.ts"
  ],
  "permission": {
    "lsp": "allow",
    "edit": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "read": "allow"
  },
  "provider": {
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    },
    "openai": {
      "models": {
        "gpt-5.4": {
          "limit": {
            "context": 200000,
            "output": 128000
          }
        }
      }
    }
  },
  "mcp": {
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "environment": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer {env:NOTION_API_TOKEN}\", \"Notion-Version\": \"2022-06-28\"}"
      },
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true
    },
    "gitmcp": {
      "type": "remote",
      "url": "https://gitmcp.io/https://github.com/anomalyco/opencode/https://github.com/anomalyco/opencode",
      "enabled": true,
      "timeout": 15000
    },
    "fetcher": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "fetcher-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true,
      "timeout": 15000
    },
    "desktop-commander": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@smithery/cli@latest",
        "run",
        "@wonderwhy-er/desktop-commander",
        "--key",
        "{env:SMITHERY_CLI_KEY}"
      ],
      "enabled": true
    },
    "exa": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.exa.ai/mcp"
      ],
      "environment": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      },
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
      },
      "enabled": true
    },
    "mcp-playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false
    },
    "netlify": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@netlify/mcp"
      ],
      "environment": {
        "NETLIFY_PERSONAL_ACCESS_TOKEN": "{env:NETLIFY_PAT}"
      },
      "enabled": false
    },
    "repomix": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "repomix",
        "--mcp"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}",
      "enabled": true,
      "timeout": 15000
    },
    "z-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "web-prime-search": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      },
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": true
    }
  }
}