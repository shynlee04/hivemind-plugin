{
  "mcpServers": {
    "notion": {
      "httpUrl": "https://mcp.notion.com/mcp",
      "headers": {
        "Authorization": "Bearer $NOTION_API_TOKEN"
      },
      "timeout": 15000
    },
    "stitch": {
      "httpUrl": "https://stitch.googleapis.com/mcp"
    },
    "gitmcp": {
      "httpUrl": "https://gitmcp.io",
      "timeout": 35000
    },
    "fetcher": {
      "command": "npx",
      "args": [
        "-y",
        "fetcher-mcp"
      ],
      "timeout": 30000
    },
    "web-search-prime": {
      "httpUrl": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer $ZAI_API_KEY"
      }
    },
    "web-reader": {
      "httpUrl": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer $ZAI_API_KEY"
      }
    },
    "zread": {
      "httpUrl": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer $ZAI_API_KEY"
      }
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp"
    },
    "deepwiki": {
      "httpUrl": "https://mcp.deepwiki.com/mcp",
      "timeout": 15000
    },
    "desktop-commander": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@wonderwhy-er/desktop-commander",
        "--key",
        "$SMITHERY_CLI_KEY"
      ]
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.exa.ai/mcp"
      ],
      "env": {
        "EXA_API_KEY": "$EXA_API_KEY"
      }
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PAT"
      }
    },
    "mcp-playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "netlify": {
      "command": "npx",
      "args": [
        "-y",
        "@netlify/mcp"
      ],
      "env": {
        "NETLIFY_PERSONAL_ACCESS_TOKEN": "$NETLIFY_PAT"
      }
    },
    "repomix": {
      "command": "npx",
      "args": [
        "-y",
        "repomix",
        "--mcp"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "tavily": {
      "httpUrl": "https://mcp.tavily.com/mcp/?tavilyApiKey=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",
      "timeout": 35000
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "env": {
        "BRAVE_API_KEY": "$BRAVE_API_KEY"
      }
    }
  }
}