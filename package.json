{
  "name": "opencode-harness",
  "version": "0.1.0",
  "description": "Multi-agent checkpoint orchestration framework for OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "scripts": {
    "clean": "node --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.19",
    "bun-pty": "^0.4.8",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.19"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "opencode": ">=1.14.19"
  }
}
