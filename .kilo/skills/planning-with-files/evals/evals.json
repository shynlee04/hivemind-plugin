{
  "skill": "planning-with-files",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "TC-001",
      "name": "No planning files — init session",
      "input": "Plan out the implementation of a new auth system",
      "expected": {
        "should_trigger": true,
        "action": "init-session",
        "files_created": ["task_plan.md", "findings.md", "progress.md"]
      },
      "assertions": [
        "Skill triggers on planning request",
        "init-session.sh creates skeleton files",
        "task_plan.md has Goal section filled from user request"
      ]
    },
    {
      "id": "TC-002",
      "name": "Existing planning files — resume",
      "input": "continue where we left off",
      "expected": {
        "should_trigger": true,
        "action": "resume",
        "files_read": ["task_plan.md", "findings.md", "progress.md"]
      },
      "assertions": [
        "Skill triggers on continuation request",
        "Reads all 3 planning files",
        "Resumes from last in_progress phase"
      ]
    },
    {
      "id": "TC-003",
      "name": "Simple task — should NOT trigger",
      "input": "add a console.log to index.ts",
      "expected": {
        "should_trigger": false,
        "reason": "Single-file edit — no planning needed"
      },
      "assertions": [
        "Skill does NOT trigger on simple task",
        "Agent executes directly"
      ]
    },
    {
      "id": "TC-004",
      "name": "Goal refresh after 5 tool calls",
      "input": "continue the implementation",
      "expected": {
        "should_trigger": true,
        "goal_refresh": true,
        "tool_call_threshold": 5
      },
      "assertions": [
        "Pre-Tool-Use Checklist runs before Write/Edit/Bash",
        "If tool_calls_since_plan_read >= 5, re-reads task_plan.md",
        "Counter resets after plan read"
      ]
    },
    {
      "id": "TC-005",
      "name": "3-Strike Protocol on repeated error",
      "input": "the test keeps failing with TypeError",
      "expected": {
        "should_trigger": true,
        "strike": 1,
        "max_strikes": 3,
        "escalation_after_3": true
      },
      "assertions": [
        "Error logged in Errors Encountered table",
        "Strike 1: diagnose and fix",
        "Strike 2: different approach",
        "Strike 3: question assumptions",
        "After 3: escalate to user"
      ]
    }
  ]
}
