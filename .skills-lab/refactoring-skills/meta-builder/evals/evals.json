{
  "skill": "meta-builder",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "TC-001",
      "name": "Clear skill creation intent",
      "input": "create a skill like this @.kilo/command/deep-research.md",
      "expected": {
        "preflight_passes": true,
        "primary_skill": "use-authoring-skills",
        "stack_skills": ["skill-creator"],
        "group": "GROUP_2",
        "questions_allowed": 0
      },
      "assertions": [
        "preflight.sh exits 0",
        "PRIMARY_SKILL equals use-authoring-skills",
        "GROUP equals GROUP_2",
        "No questions needed — intent is clear"
      ]
    },
    {
      "id": "TC-002",
      "name": "Vague intent requires probing",
      "input": "help me figure out what I want to build",
      "expected": {
        "preflight_passes": true,
        "primary_skill": "user-intent-interactive-loop",
        "stack_skills": [],
        "group": "GROUP_1",
        "questions_allowed": 3
      },
      "assertions": [
        "preflight.sh exits 0",
        "PRIMARY_SKILL equals user-intent-interactive-loop",
        "GROUP equals GROUP_1",
        "Questions allowed — intent needs clarification"
      ]
    },
    {
      "id": "TC-003",
      "name": "Empty input blocked",
      "input": "",
      "expected": {
        "preflight_passes": false,
        "error": "Empty request"
      },
      "assertions": [
        "preflight.sh exits 1",
        "Error message mentions empty request"
      ]
    },
    {
      "id": "TC-004",
      "name": "Multi-domain stacking",
      "input": "create a skill and coordinate agents to build it in parallel",
      "expected": {
        "preflight_passes": true,
        "primary_skill": "use-authoring-skills",
        "stack_skills": ["coordinating-loop"],
        "group": "GROUP_2"
      },
      "assertions": [
        "preflight.sh exits 0",
        "PRIMARY_SKILL equals use-authoring-skills",
        "STACK_SKILLS includes coordinating-loop"
      ]
    },
    {
      "id": "TC-005",
      "name": "Should NOT trigger on unrelated requests",
      "input": "fix the bug in my auth module",
      "expected": {
        "should_trigger": false,
        "reason": "No skill/command/tool creation intent detected"
      },
      "assertions": [
        "preflight.sh exits 0 but routes to no specialist",
        "No GROUP_1 or GROUP_2 score exceeds threshold"
      ]
    }
  ]
}
