{
  "chain_id": "chain-4",
  "name": "Session recovery after /clear",
  "user_prompt": "continue where we left off on the deep-research skill",
  "layers": [
    {
      "layer": 0,
      "skill": "meta-builder",
      "script": "scripts/preflight.sh",
      "input": "continue where we left off on the deep-research skill",
      "fixture": "base-state",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PRIMARY_SKILL is user-intent-interactive-loop (resume/continue)", "pattern": "PRIMARY_SKILL=user-intent-interactive-loop"},
        {"text": "GROUP is GROUP_1 (process/resume intent)", "pattern": "GROUP=GROUP_1"},
        {"text": "PREFLIGHT_PASSED is true", "pattern": "PREFLIGHT_PASSED=true"}
      ],
      "state_output": {
        "PRIMARY_SKILL": "user-intent-interactive-loop",
        "GROUP": "GROUP_1"
      }
    },
    {
      "layer": 1,
      "skill": "user-intent-interactive-loop",
      "script": "scripts/intent-verify.sh",
      "input": "--probe",
      "fixture": "session-recovery",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PROBE conditions met", "pattern": "RESULT: PASS"},
        {"text": "Phase is UNDERSTAND (reading existing state)", "pattern": "UNDERSTAND"},
        {"text": "No failed conditions", "pattern": "Failed: 0"}
      ],
      "state_output": {
        "phase": "UNDERSTAND",
        "intent_confirmed": true
      }
    },
    {
      "layer": 2,
      "skill": "planning-with-files",
      "script": "scripts/check-complete.sh",
      "input": "",
      "fixture": "session-recovery",
      "expected_exit_code": 1,
      "assertions": [
        {"text": "Goal section present", "pattern": "## Goal"},
        {"text": "Partial phases found", "pattern": "### Phase"},
        {"text": "Phase summary shows in-progress state", "pattern": "Phase Summary"}
      ],
      "state_output": {
        "planning_files": ["task_plan.md", "findings.md", "progress.md"],
        "goal_refresh_triggered": true
      }
    },
    {
      "layer": 3,
      "skill": "coordinating-loop",
      "script": "scripts/check-gate.sh",
      "input": "eval-session G1",
      "fixture": "coordination-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "G1 passes (tasks exist)", "pattern": "\\[gate-G1\\] PASS"},
        {"text": "Resumes from last valid checkpoint", "pattern": "task"}
      ],
      "state_output": {
        "gates_passed": ["G1"],
        "checkpoint_restored": true
      }
    },
    {
      "layer": 4,
      "skill": "use-authoring-skills",
      "script": "scripts/validate-gate.sh",
      "input": "create \"Deep Research Skill\" .",
      "fixture": "session-recovery",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Gate 0 passes (valid action)", "pattern": "GATE OK"},
        {"text": "Gate 1 passes (intent extracted)", "pattern": "GATE OK: Intent"},
        {"text": "Gate 2 passes (planning files exist with goal)", "pattern": "GATE OK: task_plan.md Goal present"}
      ],
      "state_output": {
        "gates_passed": ["G0", "G1", "G2"],
        "resumed_from_checkpoint": true
      }
    }
  ],
  "cross_layer_assertions": [
    {"text": "Layer 0 routes to resume path with GROUP_1", "pattern": ""},
    {"text": "Layer 1 UNDERSTAND reads progress.md and task_plan.md", "pattern": ""},
    {"text": "Layer 2 session-catchup with goal-refresh triggered", "pattern": ""},
    {"text": "Layer 3 checks gate status and resumes from checkpoint", "pattern": ""},
    {"text": "Layer 4 continues from last validated state", "pattern": ""},
    {"text": "No data loss — all prior work preserved", "pattern": ""},
    {"text": "Checkpoint restored and goal-refresh confirmed", "pattern": ""}
