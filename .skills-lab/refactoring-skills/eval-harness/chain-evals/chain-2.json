{
  "chain_id": "chain-2",
  "name": "Audit and fix an existing skill",
  "user_prompt": "Audit the meta-builder skill — it's not routing correctly for multi-intent requests",
  "layers": [
    {
      "layer": 0,
      "skill": "meta-builder",
      "script": "scripts/preflight.sh",
      "input": "Audit the meta-builder skill — it's not routing correctly for multi-intent requests",
      "fixture": "base-state",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PRIMARY_SKILL is use-authoring-skills (audit path)", "pattern": "PRIMARY_SKILL=use-authoring-skills"},
        {"text": "GROUP is GROUP_2 (audit+skill matches creation pattern)", "pattern": "GROUP=GROUP_2"},
        {"text": "PREFLIGHT_PASSED is true", "pattern": "PREFLIGHT_PASSED=true"}
      ],
      "state_output": {
        "PRIMARY_SKILL": "use-authoring-skills",
        "GROUP": "GROUP_2"
      }
    },
    {
      "layer": 1,
      "skill": "user-intent-interactive-loop",
      "script": "scripts/intent-verify.sh",
      "input": "--probe",
      "fixture": "audit-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PROBE conditions met", "pattern": "RESULT: PASS"},
        {"text": "No failed conditions", "pattern": "Failed: 0"},
        {"text": "Intent phase is UNDERSTAND", "pattern": "UNDERSTAND"}
      ],
      "state_output": {
        "phase": "UNDERSTAND",
        "intent_confirmed": true
      }
    },
    {
      "layer": 2,
      "skill": "planning-with-files",
      "script": "scripts/check-complete.sh",
      "input": "",
      "fixture": "audit-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Goal section present", "pattern": "## Goal"},
        {"text": "Fix phases defined", "pattern": "### Phase"},
        {"text": "Phase summary output", "pattern": "Phase Summary"}
      ],
      "state_output": {
        "planning_files": ["task_plan.md", "findings.md"]
      }
    },
    {
      "layer": 3,
      "skill": "coordinating-loop",
      "script": "scripts/check-gate.sh",
      "input": "eval-session G1",
      "fixture": "coordination-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "G1 passes (tasks exist)", "pattern": "\\[gate-G1\\] PASS"},
        {"text": "Task count reported", "pattern": "task"}
      ],
      "state_output": {
        "gates_passed": ["G1"]
      }
    },
    {
      "layer": 4,
      "skill": "use-authoring-skills",
      "script": "scripts/validate-gate.sh",
      "input": "audit \"meta-builder routing issues\" .",
      "fixture": "audit-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Gate 0 passes (valid action: audit)", "pattern": "GATE OK"},
        {"text": "Gate 1 passes (intent extracted)", "pattern": "GATE OK: Intent"},
        {"text": "Gate 5 passes (SKILL.md exists for audit)", "pattern": "GATE OK: Target SKILL.md exists"}
      ],
      "state_output": {
        "gates_passed": ["G0", "G1", "G5"]
      }
    }
  ],
  "cross_layer_assertions": [
    {"text": "Layer 0 routes to audit path with GROUP_2 (audit+skill pattern)", "pattern": ""},
    {"text": "Layer 1 UNDERSTAND phase reads existing audit state", "pattern": ""},
    {"text": "Layer 2 resumes from existing task_plan.md with fix phases", "pattern": ""},
    {"text": "Layer 3 G1 passes with audit tasks identified", "pattern": ""},
    {"text": "Layer 4 audit gates pass with SKILL.md target found", "pattern": ""},
    {"text": "Audit report generated with categorized issues", "pattern": ""}
  ],
  "expected_total_duration_ms": 5000
}
