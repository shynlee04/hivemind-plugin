{
  "chain_id": "chain-5",
  "name": "Multi-skill stacked workflow",
  "user_prompt": "Create a new skill, then set up a test harness for it, then optimize its triggers",
  "layers": [
    {
      "layer": 0,
      "skill": "meta-builder",
      "script": "scripts/preflight.sh",
      "input": "Create a new skill, then set up a test harness for it, then optimize its triggers",
      "fixture": "base-state",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PRIMARY_SKILL is use-authoring-skills (creation intent)", "pattern": "PRIMARY_SKILL=use-authoring-skills"},
        {"text": "GROUP is GROUP_2 (creation intent)", "pattern": "GROUP=GROUP_2"},
        {"text": "STACK_SKILLS includes coordinating-loop", "pattern": "STACK_SKILLS="},
        {"text": "PREFLIGHT_PASSED is true", "pattern": "PREFLIGHT_PASSED=true"}
      ],
      "state_output": {
        "PRIMARY_SKILL": "use-authoring-skills",
        "GROUP": "GROUP_2",
        "multi_phase": true
      }
    },
    {
      "layer": 1,
      "skill": "user-intent-interactive-loop",
      "script": "scripts/intent-verify.sh",
      "input": "--probe",
      "fixture": "multi-phase-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PROBE conditions met", "pattern": "RESULT: PASS"},
        {"text": "3-part scope confirmed", "pattern": "multi_phase"},
        {"text": "No failed conditions", "pattern": "Failed: 0"}
      ],
      "state_output": {
        "intent_confirmed": true,
        "scope_parts": 3
      }
    },
    {
      "layer": 2,
      "skill": "planning-with-files",
      "script": "scripts/check-complete.sh",
      "input": "",
      "fixture": "multi-phase-active",
      "expected_exit_code": 1,
      "assertions": [
        {"text": "Goal section present", "pattern": "## Goal"},
        {"text": "3-section task_plan.md", "pattern": "### Section"},
        {"text": "Phase summary output", "pattern": "Phase Summary"}
      ],
      "state_output": {
        "planning_files": ["task_plan.md", "findings.md", "progress.md"],
        "sections": ["create", "test", "optimize"]
      }
    },
    {
      "layer": 3,
      "skill": "coordinating-loop",
      "script": "scripts/check-gate.sh",
      "input": "eval-session G1",
      "fixture": "coordination-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "G1 passes (tasks exist)", "pattern": "\\[gate-G1\\] PASS"},
        {"text": "Sequential phases: create → test → optimize", "pattern": "task"}
      ],
      "state_output": {
        "gates_passed": ["G1"],
        "execution_mode": "sequential"
      }
    },
    {
      "layer": 4,
      "skill": "use-authoring-skills",
      "script": "scripts/validate-gate.sh",
      "input": "create \"Multi-Phase Skill\" .",
      "fixture": "multi-phase-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Gate 0 passes (valid action)", "pattern": "GATE OK"},
        {"text": "Gate 1 passes (intent extracted)", "pattern": "GATE OK: Intent"},
        {"text": "Gate 2 passes (planning files exist)", "pattern": "GATE OK: task_plan.md Goal present"}
      ],
      "state_output": {
        "gates_passed": ["G0", "G1", "G2"],
        "phases_completed": ["create", "test", "optimize"]
      }
    }
  ],
  "cross_layer_assertions": [
    {"text": "Layer 0 routes to creation with stacked skills", "pattern": ""},
    {"text": "Layer 1 PROBE confirms 3-part scope", "pattern": ""},
    {"text": "Layer 2 init-session creates 3-section task_plan.md", "pattern": ""},
    {"text": "Layer 3 sequential phases: create → test → optimize", "pattern": ""},
    {"text": "Layer 4 executes each phase with validation gates", "pattern": ""},
    {"text": "3 phases completed in order, each validated before next", "pattern": ""}
  ],
  "expected_total_duration_ms": 5000
}
