{
  "chain_id": "chain-1",
  "name": "Create a new skill from scratch",
  "user_prompt": "Create a skill for API rate limiting that works across OpenCode and Claude Code",
  "layers": [
    {
      "layer": 0,
      "skill": "meta-builder",
      "script": "scripts/preflight.sh",
      "input": "Create a skill for API rate limiting that works across OpenCode and Claude Code",
      "fixture": "base-state",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PRIMARY_SKILL is use-authoring-skills", "pattern": "PRIMARY_SKILL=use-authoring-skills"},
        {"text": "GROUP is GROUP_2 (creation intent)", "pattern": "GROUP=GROUP_2"},
        {"text": "QUESTIONS_ALLOWED is 2 (clear creation intent)", "pattern": "QUESTIONS_ALLOWED=2"},
        {"text": "PREFLIGHT_PASSED is true", "pattern": "PREFLIGHT_PASSED=true"}
      ],
      "state_output": {
        "PRIMARY_SKILL": "use-authoring-skills",
        "GROUP": "GROUP_2",
        "QUESTIONS_ALLOWED": "2"
      }
    },
    {
      "layer": 1,
      "skill": "user-intent-interactive-loop",
      "script": "scripts/intent-verify.sh",
      "input": "--probe",
      "fixture": "intent-confirmed",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PROBE conditions all met", "pattern": "RESULT: PASS"},
        {"text": "No failed conditions", "pattern": "Failed: 0"},
        {"text": "User confirmation section present", "pattern": "User confirmed"}
      ],
      "state_output": {
        "intent_confirmed": true
      }
    },
    {
      "layer": 2,
      "skill": "planning-with-files",
      "script": "scripts/check-complete.sh",
      "input": "",
      "fixture": "planning-active",
      "expected_exit_code": 1,
      "assertions": [
        {"text": "Goal section present in plan", "pattern": "Goal"},
        {"text": "Phases defined", "pattern": "Phase"},
        {"text": "Phase summary output", "pattern": "Phase Summary"}
      ],
      "state_output": {
        "planning_files": ["task_plan.md", "findings.md", "progress.md"]
      }
    },
    {
      "layer": 3,
      "skill": "coordinating-loop",
      "script": "scripts/check-gate.sh",
      "input": "eval-session G1",
      "fixture": "coordination-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "G1 passes (tasks exist)", "pattern": "\\[gate-G1\\] PASS"},
        {"text": "Task count >= 2", "pattern": "3 task"}
      ],
      "state_output": {
        "gates_passed": ["G1"]
      }
    },
    {
      "layer": 4,
      "skill": "use-authoring-skills",
      "script": "scripts/validate-gate.sh",
      "input": "create \"API Rate Limiter\" .",
      "fixture": "planning-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Gate 0 passes (valid action)", "pattern": "GATE OK"},
        {"text": "Gate 1 passes (intent extracted)", "pattern": "GATE OK: Intent"},
        {"text": "Gate 2 passes (planning files exist)", "pattern": "GATE OK: task_plan.md Goal present"}
      ],
      "state_output": {
        "gates_passed": ["G0", "G1", "G2"]
      }
    }
  ],
  "cross_layer_assertions": [
    {"text": "Layer 0 routes to use-authoring-skills (creation intent)", "pattern": ""},
    {"text": "Layer 1 confirms intent with all PROBE conditions", "pattern": ""},
    {"text": "Layer 2 finds planning files with Goal section", "pattern": ""},
    {"text": "Layer 3 G1 passes with tasks identified", "pattern": ""},
    {"text": "Layer 4 validation gates pass for create action", "pattern": ""},
    {"text": "All layers complete without blocking errors", "pattern": ""}
  ],
  "expected_total_duration_ms": 5000
}
