{
  "chain_id": "chain-3",
  "name": "Convert a command file into a skill",
  "user_prompt": "Turn this command file into a skill — it's a markdown file with CLI instructions for our devops team",
  "layers": [
    {
      "layer": 0,
      "skill": "meta-builder",
      "script": "scripts/preflight.sh",
      "input": "Turn this command file into a skill — it's a markdown file with CLI instructions for our devops team",
      "fixture": "base-state",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PRIMARY_SKILL is use-authoring-skills (create from template)", "pattern": "PRIMARY_SKILL=use-authoring-skills"},
        {"text": "GROUP is GROUP_2 (creation intent)", "pattern": "GROUP=GROUP_2"},
        {"text": "PREFLIGHT_PASSED is true", "pattern": "PREFLIGHT_PASSED=true"}
      ],
      "state_output": {
        "PRIMARY_SKILL": "use-authoring-skills",
        "GROUP": "GROUP_2"
      }
    },
    {
      "layer": 1,
      "skill": "user-intent-interactive-loop",
      "script": "scripts/intent-verify.sh",
      "input": "--probe",
      "fixture": "conversion-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "PROBE conditions met", "pattern": "RESULT: PASS"},
        {"text": "Scope bounded", "pattern": "scope_in"},
        {"text": "Success defined", "pattern": "success_criteria"},
        {"text": "No failed conditions", "pattern": "Failed: 0"}
      ],
      "state_output": {
        "intent_confirmed": true,
        "scope_bounded": true
      }
    },
    {
      "layer": 2,
      "skill": "planning-with-files",
      "script": "scripts/check-complete.sh",
      "input": "",
      "fixture": "conversion-active",
      "expected_exit_code": 1,
      "assertions": [
        {"text": "Goal section present", "pattern": "## Goal"},
        {"text": "Conversion phases generated", "pattern": "### Phase"},
        {"text": "Phase summary output", "pattern": "Phase Summary"}
      ],
      "state_output": {
        "planning_files": ["task_plan.md", "progress.md"]
      }
    },
    {
      "layer": 3,
      "skill": "coordinating-loop",
      "script": "scripts/check-gate.sh",
      "input": "eval-session G1",
      "fixture": "coordination-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "G1 passes (tasks exist)", "pattern": "\\[gate-G1\\] PASS"},
        {"text": "Parallel dispatch for 3 envelopes", "pattern": "task"}
      ],
      "state_output": {
        "gates_passed": ["G1"]
      }
    },
    {
      "layer": 4,
      "skill": "use-authoring-skills",
      "script": "scripts/validate-gate.sh",
      "input": "create \"DevOps CLI Helper\" .",
      "fixture": "conversion-active",
      "expected_exit_code": 0,
      "assertions": [
        {"text": "Gate 0 passes (valid action)", "pattern": "GATE OK"},
        {"text": "Gate 1 passes (intent extracted)", "pattern": "GATE OK: Intent"},
        {"text": "Gate 2 passes (planning files exist)", "pattern": "GATE OK: task_plan.md Goal present"}
      ],
      "state_output": {
        "gates_passed": ["G0", "G1", "G2"]
      }
    }
  ],
  "cross_layer_assertions": [
    {"text": "Layer 0 routes to creation path with GROUP_2", "pattern": ""},
    {"text": "Layer 1 PROBE confirms scope bounded and success defined", "pattern": ""},
    {"text": "Layer 2 conversion phases generated in task_plan.md", "pattern": ""},
    {"text": "Layer 3 G1 passes with parallel dispatch tasks", "pattern": ""},
    {"text": "Layer 4 create gates pass for conversion output", "pattern": ""},
    {"text": "Input file parsed and output skill structure complete", "pattern": ""}
  ],
  "expected_total_duration_ms": 5000
}
