    "native_task_integration": {
      "description": "OpenCode's native 'task' tool is NOT implemented by Hivemind. It is built into the OpenCode runtime. Hivemind hooks into its lifecycle via tool.execute.before/after and chat.message hooks.",
      "hooks_that_capture_task": [
        "tool.execute.before — src/hooks/transforms/tool-before-guard.ts:40 — detects 'task' tool",
        "tool.execute.after — src/features/session-tracker/index.ts:312-316 — records child tool journey and task delegation",
        "chat.message — src/plugin.ts:548-563 — captures delegation result",
        "session.idle — src/features/session-tracker/capture/handlers/session-idle-handler.ts — marks child completed"
      ],
      "what_session_tracker_records_for_task": [
        "Child .json file with ChildSessionRecord (sessionID, parentSessionID, delegationDepth, delegatedBy, mainAgent, turns, journey)",
        "Hierarchy manifest entry (hierarchy-manifest.json)",
        "Session index entry (session-continuity.json)",
        "Project index entry (project-continuity.json)",
        "Journey entries (tool_call dispatch, assistant_message result)",
        "Turn records (user delegation prompt, assistant result)",
        "Status transitions (active → completed)"
      ],
      "what_is_NOT_recorded": [
        "Trajectory record — no automatic trajectory creation",
        "Agent work contract — no automatic contract creation",
        "Delegation record in DelegationManager — native task has no DelegationManager integration",
        "Notification to parent — no NotificationRouter integration for native task",
        "Periodic progress updates — no PeriodicNotifier for native task",
        "Dual-signal completion — native task uses session.idle only, not CompletionDetector"
      ]
    }
