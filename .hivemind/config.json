{
  "governance_mode": "strict",
  "language": "vi",
  "max_turns_before_warning": 5,
  "max_active_md_lines": 300,
  "auto_compact_on_turns": 50,
  "stale_session_days": 7,
  "commit_suggestion_threshold": 15,
  "max_context_tokens": 60000,
  "agent_behavior": {
    "expert_level": "advanced",
    "output_style": "explanatory",
    "constraints": {
      "enforce_tdd": false,
      "require_code_review": true,
      "be_skeptical": true
    }
  },
  "automation": {
    "auto_save_mems": true,
    "auto_archive_sessions": true,
    "auto_detect_drift": true
  }
}
