{
  "root": "root",
  "elements": {
    "heading": {
      "type": "Heading",
      "props": {
        "text": "Hivefiver Settings Dashboard",
        "level": "h1"
      }
    },
    "left-session-id": {
      "type": "Text",
      "props": {
        "text": "Session: ses_wiring_test",
        "variant": "body"
      }
    },
    "left-authority": {
      "type": "Text",
      "props": {
        "text": "Authority: attached-sdk",
        "variant": "body"
      }
    },
    "left-attachment": {
      "type": "Text",
      "props": {
        "text": "Mode: local-worktree",
        "variant": "body"
      }
    },
    "left-health-badge": {
      "type": "Badge",
      "props": {
        "text": "healthy",
        "variant": "secondary"
      }
    },
    "left-event-0": {
      "type": "Text",
      "props": {
        "text": "• test-event",
        "variant": "caption"
      }
    },
    "left-card": {
      "type": "Card",
      "props": {
        "title": "40 pane · runtime/session mirror",
        "description": "Gate: ready",
        "maxWidth": "md"
      },
      "children": [
        "left-session-id",
        "left-authority",
        "left-attachment",
        "left-health-badge",
        "left-event-0"
      ]
    },
    "right-language-select": {
      "type": "Select",
      "props": {
        "label": "Language",
        "name": "chatLanguage",
        "options": [
          "en"
        ],
        "value": {
          "$bindState": "/selectedLanguage"
        },
        "placeholder": "Select language"
      }
    },
    "right-settings-tabs": {
      "type": "Tabs",
      "props": {
        "tabs": [
          {
            "label": "Identity",
            "value": "identity"
          },
          {
            "label": "Expertise",
            "value": "expertise"
          },
          {
            "label": "Governance",
            "value": "governance"
          }
        ],
        "defaultValue": "identity",
        "value": {
          "$bindState": "/activeTab"
        }
      }
    },
    "right-input-preferredUserName": {
      "type": "Input",
      "props": {
        "label": "Display Name",
        "name": "preferredUserName",
        "type": "text",
        "placeholder": "Enter your name",
        "value": {
          "$bindState": "/inputValues/preferredUserName"
        }
      }
    },
    "right-settings": {
      "type": "Text",
      "props": {
        "text": "preferredUserName: Alice\nchatLanguage: vi\nartifactLanguage: en\nexpertiseLevel: intermediate\ngovernanceMode: standard\nautomationLevel: guided\noutputStyle: concise",
        "variant": "body"
      }
    },
    "right-next-action": {
      "type": "Text",
      "props": {
        "text": "Next: refresh-session-guidance",
        "variant": "lead"
      }
    },
    "right-guidance-0": {
      "type": "Text",
      "props": {
        "text": "• question-gate satisfied",
        "variant": "caption"
      }
    },
    "right-changes-badge": {
      "type": "Badge",
      "props": {
        "text": "1 changed",
        "variant": "secondary"
      }
    },
    "right-btn-save": {
      "type": "Button",
      "props": {
        "label": "Save",
        "variant": "primary",
        "disabled": null
      },
      "on": {
        "press": {
          "action": "saveSettings",
          "params": {}
        }
      }
    },
    "right-btn-reset": {
      "type": "Button",
      "props": {
        "label": "Reset",
        "variant": "secondary",
        "disabled": null
      },
      "on": {
        "press": {
          "action": "resetSettings",
          "params": {}
        }
      }
    },
    "right-card": {
      "type": "Card",
      "props": {
        "title": "60 pane · Hivefiver settings",
        "maxWidth": "md"
      },
      "children": [
        "right-language-select",
        "right-settings-tabs",
        "right-input-preferredUserName",
        "right-settings",
        "right-next-action",
        "right-guidance-0",
        "right-changes-badge",
        "right-btn-save",
        "right-btn-reset"
      ]
    },
    "body": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "left-card",
        "right-card"
      ]
    },
    "root": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "lg"
      },
      "children": [
        "heading",
        "body"
      ]
    }
  },
  "state": {
    "hasChanges": true,
    "hasGuidance": true,
    "selectedLanguage": "vi",
    "selectedTheme": "auto",
    "activeTab": "identity",
    "inputValues": {
      "preferredUserName": "Alice"
    }
  }
}