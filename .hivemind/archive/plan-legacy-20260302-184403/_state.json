{
  "version": "1.0.0",
  "schema": "hivemind-plan-state-v1",
  "created": "2026-03-03",
  "last_updated": "2026-03-03",
  "plans": {
    "META01": {
      "title": "Hivefiver Domain Restructure",
      "status": "open",
      "scope": "meta",
      "owner": "hivefiver",
      "children": [],
      "completion_pct": 0,
      "created": "2026-03-03"
    }
  },
  "state_flow": {
    "transitions": {
      "open": ["routing"],
      "routing": ["branching", "pivoted"],
      "branching": ["in_progress"],
      "in_progress": ["completed", "pivoted", "branching"],
      "completed": ["closed"],
      "pivoted": ["open", "closed"],
      "closed": []
    },
    "terminal": ["closed"],
    "completion_rule": "All children must be 'completed' or 'pivoted' before parent can transition to 'completed'."
  },
  "naming": {
    "root_pattern": "[TYPE][ID]-PLAN.md",
    "sub_pattern": "[TYPE][ID]-SUB[NN]-PLAN.md",
    "atomic_pattern": "[TYPE][ID]-SUB[NN]-A[NN]-PLAN.md",
    "validation_pattern": "VALIDATION-[TYPE][ID]-PLAN.md",
    "verification_pattern": "VERIFICATION-[TYPE][ID]-IMPLEMENTATION.md",
    "pivot_pattern": "PIVOT-[TYPE][ID]-[YYYY-MM-DD].md",
    "types": {
      "META": "meta-framework tasks (agents, skills, commands, workflows)",
      "PROJ": "project-specific tasks (src, tests, features)"
    }
  },
  "paths": {
    "root": ".hivemind/plan/",
    "sub": ".hivemind/plan/sub-plan/",
    "atomic": ".hivemind/plan/sub-plan/atomic-plan/",
    "templates": ".hivemind/plan/_templates/"
  }
}
